<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Framework\View\Element\Message\MessageConfigurationsPool">
        <arguments>
            <argument name="configurationsMap" xsi:type="array">
                <item name="colissimoCgv" xsi:type="array">
                    <item name="renderer" xsi:type="const">\Magento\Framework\View\Element\Message\Renderer\BlockRenderer::CODE</item>
                    <item name="data" xsi:type="array">
                        <item name="template" xsi:type="string">LaPoste_Colissimo::messages/cgvLink.phtml</item>
                    </item>
                </item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Framework\Notification\MessageList">
        <arguments>
            <argument name="messages" xsi:type="array">
                <item name="customMessageNotification" xsi:type="string">LaPoste\Colissimo\Model\System\Message\DeprecatedMethodsNotification</item>
                <item name="Notification" xsi:type="string">LaPoste\Colissimo\Model\Feedback</item>
                <item name="loginDeprecatedNotification" xsi:type="string">LaPoste\Colissimo\Model\System\Message\DeprecatedLoginNotification</item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Catalog\Model\Category\DataProvider">
        <plugin name="laposte_colissimo_category_form_plugin"
                type="LaPoste\Colissimo\Plugin\CategoryDataProviderPlugin"/>
    </type>
    <type name="Magento\Catalog\Ui\DataProvider\Product\Form\ProductDataProvider">
        <plugin name="laposte_colissimo_product_form_plugin"
                type="LaPoste\Colissimo\Plugin\ProductDataProviderPlugin" />
    </type>
</config>

